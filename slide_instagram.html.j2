<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
  {% if fonts_css_url %}
  @import url('{{ fonts_css_url }}');
  {% else %}
  @import url('https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap');
  {% endif %}

  * {
    margin: 0; padding: 0; box-sizing: border-box;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  @page {
    size: 1080px 1080px;
    margin: 0;
  }

  body {
    width: 1080px;
    height: 1080px;
    overflow: hidden;
    background: {{ theme.bg }};
    font-family: 'Manrope', sans-serif;
    color: {{ theme.text }};
    position: relative;
  }

  /* ── SLIDE CONTAINER ── */
  .ig-slide {
    width: 1080px;
    height: 1080px;
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── BACKGROUND LAYER ── */
  .ig-bg {
    position: absolute;
    inset: 0;
    {% if theme.bg_gradient %}
    background: {{ theme.bg_gradient }};
    {% else %}
    background: {{ theme.bg }};
    {% endif %}
    z-index: 0;
  }

  /* Ambient glows */
  .ig-glow-1 {
    position: absolute;
    width: 700px; height: 700px;
    top: -150px; left: -150px;
    background: radial-gradient(circle, {{ theme.blob1 }}60 0%, transparent 65%);
    z-index: 1;
    pointer-events: none;
  }
  .ig-glow-2 {
    position: absolute;
    width: 600px; height: 600px;
    bottom: 50px; right: -100px;
    background: radial-gradient(circle, {{ theme.blob2 }}50 0%, transparent 65%);
    z-index: 1;
    pointer-events: none;
  }

  /* Subtle dot-grid texture */
  .ig-texture {
    position: absolute;
    inset: 0;
    background-image: radial-gradient({{ theme.accent1 }}12 1px, transparent 1px);
    background-size: 32px 32px;
    z-index: 1;
    pointer-events: none;
  }

  /* ── TOP BAR ── */
  .ig-topbar {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 36px 72px 0 72px;
    flex-shrink: 0;
  }
  .ig-counter {
    font-family: 'JetBrains Mono', monospace;
    font-size: 20px;
    font-weight: 700;
    color: {{ theme.text_muted }};
    letter-spacing: 0.08em;
    background: {{ theme.surface | default('rgba(255,255,255,0.08)') }};
    padding: 8px 18px;
    border-radius: 100px;
    border: 1px solid {{ theme.accent1 }}30;
  }

  /* ── MAIN CONTENT AREA ── */
  .ig-content {
    position: relative;
    z-index: 5;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 24px 72px 0 72px;
    min-height: 0;
  }

  /* ── FOOTER ── */
  .ig-footer {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 72px 36px 72px;
    flex-shrink: 0;
    border-top: 1px solid {{ theme.accent1 }}20;
    margin-top: 20px;
  }
  .ig-footer-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ig-footer-series {
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: {{ theme.accent1 }};
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .ig-footer-author {
    font-family: 'Manrope', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: {{ theme.text_muted }};
  }
  .ig-footer-logo {
    height: 96px;
    width: auto;
    object-fit: contain;
    {% if theme.is_light %}opacity: 0.85;{% endif %}
  }
  /* Accent rule under footer separator */
  .ig-footer::before {
    content: '';
    position: absolute;
    top: -1px; left: 72px;
    width: 60px;
    height: 3px;
    background: {{ theme.rule }};
    border-radius: 2px;
  }

  /* ── BADGE ── */
  .ig-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Manrope', sans-serif;
    font-size: 17px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ theme.bg }};
    background: {{ theme.accent1 }};
    padding: 8px 20px;
    border-radius: 100px;
    margin-bottom: 28px;
    align-self: flex-start;
  }

  /* ── ACCENT RULE ── */
  .ig-rule {
    width: 80px;
    height: 5px;
    background: {{ theme.rule }};
    border-radius: 3px;
    margin-bottom: 28px;
    flex-shrink: 0;
  }

  /* ════════════════════════════════════════════
     COVER SLIDE
  ════════════════════════════════════════════ */
  .ig-cover-logo {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 28px;
  }
  .ig-cover-logo img {
    height: 350px;
    width: auto;
    object-fit: contain;
    {% if theme.is_light %}opacity: 0.85;{% endif %}
  }

  .ig-cover-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .ig-cover-eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: {{ theme.accent1 }};
    margin-bottom: 24px;
  }

  .ig-cover-title {
    font-family: 'Clash Display', sans-serif;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: {{ theme.text }};
    text-transform: uppercase;
    word-break: break-word;
    hyphens: auto;
    margin-bottom: 24px;
  }

  .ig-cover-sub {
    font-family: 'Manrope', sans-serif;
    font-size: 28px;
    font-weight: 500;
    line-height: 1.55;
    color: {{ theme.text_muted }};
    max-width: 820px;
    margin-bottom: 48px;
  }

  /* Cover swipe CTA */
  .ig-cta {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    align-self: center;
  }
  .ig-cta-arrow {
    width: 56px; height: 56px;
    border: 2.5px solid {{ theme.accent1 }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    color: {{ theme.accent1 }};
  }
  .ig-cta-label {
    font-family: 'Clash Display', sans-serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ theme.accent1 }};
  }

  /* Decorative cover accent block */
  .ig-cover-accent-bar {
    position: absolute;
    right: 0;
    top: 180px;
    width: 8px;
    height: 280px;
    background: {{ theme.rule }};
    border-radius: 4px 0 0 4px;
    z-index: 3;
  }

  /* ════════════════════════════════════════════
     CONTENT SLIDE
  ════════════════════════════════════════════ */
  .ig-title {
    font-family: 'Clash Display', sans-serif;
    font-size: {% if slide.is_compact %}48px{% else %}58px{% endif %};
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: {{ theme.text }};
    word-break: break-word;
    hyphens: auto;
    margin-bottom: {% if slide.is_compact %}16px{% else %}24px{% endif %};
  }

  .ig-body {
    font-family: 'Manrope', sans-serif;
    font-size: {{ slide.text_size | default(32) }}px;
    line-height: 1.6;
    color: {{ theme.text_muted }};
    flex: 0 1 auto;
    margin-top: 10px;
  }
  .ig-body p { margin-bottom: 1em; }
  .ig-body p:last-child { margin-bottom: 0; }

  .ig-body .slide-h3 {
    font-family: 'Clash Display', sans-serif;
    font-size: {{ (slide.text_size | default(32)) + 6 }}px;
    font-weight: 700;
    color: {{ theme.accent1 }};
    margin-top: 0.8em;
    margin-bottom: 0.4em;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .ig-body .slide-h4 {
    font-family: 'Manrope', sans-serif;
    font-size: {{ slide.text_size | default(32) }}px;
    font-weight: 700;
    color: {{ theme.accent2 }};
    margin-top: 0.5em;
    margin-bottom: 0.2em;
    line-height: 1.3;
  }

  /* Highlights */
  .ig-body .hl1 { color: {{ theme.accent2 }}; font-weight: 700; text-decoration: underline; text-decoration-color: {{ theme.accent1 }}; text-underline-offset: 4px; }
  .ig-body .hl2 { color: {{ theme.accent3 }}; font-weight: 700; }
  .ig-body .hl3 { color: {{ theme.accent1 }}; font-weight: 700; background: {{ theme.surface | default('rgba(255,255,255,0.08)') }}; padding: 2px 8px; border-radius: 4px; }
  .ig-body .bold, .ig-body strong { color: {{ theme.text }}; font-weight: 700; }
  .ig-body em { color: {{ theme.accent3 }}; font-style: italic; }
  .ig-body code {
    background: {{ theme.surface | default('rgba(255,255,255,0.08)') }};
    padding: 3px 9px;
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88em;
    color: {{ theme.accent2 }};
  }

  /* Bullet list */
  .ig-body .bullets {
    list-style: none;
    margin-top: 16px;
    margin-bottom: 16px;
    padding-left: 6px;
    position: relative;
  }
  .ig-body .bullets::before {
    content: '';
    position: absolute;
    left: 10px; top: 30px; bottom: 30px;
    width: 2px;
    background: linear-gradient(to bottom, {{ theme.accent1 }}, {{ theme.accent2 }});
    opacity: 0.25;
  }
  .ig-body .bullets li {
    padding: 16px 0 16px 48px;
    position: relative;
    font-size: {{ (slide.text_size | default(32)) - 2 }}px;
    color: {{ theme.text_muted }};
    line-height: 1.55;
  }
  .ig-body .bullets li::before {
    content: '';
    position: absolute;
    left: 4px; top: 26px;
    width: 14px; height: 14px;
    background: {{ theme.accent1 }};
    border-radius: 50%;
    border: 2px solid {{ theme.bg }};
  }
  .ig-body .bullets li strong { color: {{ theme.text }}; font-weight: 700; }
  .ig-body .bullets li em { color: {{ theme.accent3 }}; font-style: italic; }
  .ig-body .bullets li code {
    background: {{ theme.surface | default('rgba(255,255,255,0.08)') }};
    padding: 2px 8px;
    border-radius: 5px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88em;
    color: {{ theme.accent2 }};
  }

  /* Numbered list */
  ol.bullets.numbered {
    counter-reset: item;
    list-style: none;
  }
  ol.bullets.numbered li { counter-increment: item; }
  ol.bullets.numbered li::before {
    content: counter(item) !important;
    background: {{ theme.accent2 }};
    color: {{ theme.bg }};
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    left: 0;
    top: 22px;
    box-shadow: none;
  }

  /* Blockquote */
  .ig-body .slide-quote {
    border-left: 5px solid {{ theme.accent1 }};
    padding: 16px 24px;
    margin: 16px 0;
    background: {{ theme.surface | default('rgba(255,255,255,0.04)') }};
    border-radius: 0 12px 12px 0;
    font-style: italic;
    color: {{ theme.text_muted }};
  }

  /* HR */
  .ig-body .slide-hr {
    border: none;
    height: 2px;
    background: {{ theme.rule }};
    margin: 16px 0;
    border-radius: 2px;
  }

  /* ── IMAGES (bloc Markdown dans le body) ── */
  .slide-figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 16px 0;
    flex-shrink: 1;
  }
  .slide-image {
    max-width: 100%;
    max-height: 220px;
    width: auto;
    height: auto;
    border-radius: 14px;
    object-fit: contain;
    border: 1px solid {{ theme.accent1 }}22;
    box-shadow: 0 6px 24px rgba(0,0,0,0.22);
    display: block;
  }
  .slide-image-inline {
    max-height: 140px;
    display: inline-block;
    vertical-align: middle;
    margin: 0 6px;
  }
  .slide-image-credit {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-style: italic;
    color: {{ theme.text_muted }};
    opacity: 0.65;
    margin-top: 6px;
    text-align: center;
    max-width: 80%;
  }

  /* ── COVER : logo réduit quand une image est aussi présente ── */
  .ig-cover-logo-small img {
    height: 180px !important;
  }

  /* ── COVER : image héro sous le logo ── */
  .cover-hero-image {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    flex-shrink: 0;
  }
  .cover-hero-image img {
    max-width: 88%;
    max-height: 220px;
    object-fit: contain;
    border-radius: 18px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.35);
    border: 1px solid {{ theme.accent1 }}28;
  }

  /* ── CONTENT AVEC IMAGE : image héro grande + contenu en indice dessous ── */
  .content-hero-header {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 14px;
  }
  .content-hero-header .ig-badge { margin-bottom: 0; flex-shrink: 0; }
  .content-hero-header .ig-title {
    margin-bottom: 0;
    font-size: 34px;
    flex: 1;
    min-width: 0;
  }
  .content-hero-image-wrap {
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .content-hero-image-wrap img {
    max-width: 100%;
    max-height: 100%;
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 20px;
    box-shadow: 0 14px 56px rgba(0,0,0,0.45);
    border: 1px solid {{ theme.accent1 }}28;
  }
  .content-hero-caption {
    flex-shrink: 0;
    margin-top: 14px;
    max-height: 130px;
    overflow: hidden;
    font-family: 'Manrope', sans-serif;
    font-size: 20px;
    line-height: 1.45;
    color: {{ theme.text_muted }};
  }
  .content-hero-caption .bullets {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0; padding: 0;
    list-style: none;
  }
  .content-hero-caption .bullets::before { display: none; }
  .content-hero-caption .bullets li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px 5px 10px;
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.07)') }};
    border: 1px solid {{ theme.accent1 }}25;
    border-radius: 100px;
    font-size: 18px;
    color: {{ theme.text_muted }};
    line-height: 1.3;
  }
  .content-hero-caption .bullets li::before {
    content: '';
    width: 8px; height: 8px;
    background: {{ theme.accent1 }};
    border-radius: 50%;
    position: static;
    flex-shrink: 0;
  }
  .content-hero-caption .bullets li strong { color: {{ theme.text }}; }
  .content-hero-caption p { margin-bottom: 0.4em; }

  /* ── COMPARE : bannière compacte ── */
  .compare-image-banner {
    width: 100%;
    height: 90px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
  }
  .compare-image-banner img {
    max-height: 82px;
    max-width: 60%;
    object-fit: contain;
    border-radius: 12px;
    opacity: 0.92;
    border: 1px solid {{ theme.accent1 }}20;
  }

  /* ════════════════════════════════════════════
     QUOTE SLIDE
  ════════════════════════════════════════════ */
  .ig-quote-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 32px;
  }
  .ig-quote-mark {
    font-family: 'Clash Display', sans-serif;
    font-size: 160px;
    line-height: 0.7;
    color: {{ theme.accent1 }};
    opacity: 0.4;
    font-weight: 700;
    letter-spacing: -0.05em;
    user-select: none;
  }
  .ig-quote-text {
    font-family: 'Clash Display', sans-serif;
    font-size: {% if slide.is_compact %}46px{% else %}58px{% endif %};
    font-weight: 600;
    line-height: 1.2;
    color: {{ theme.text }};
    letter-spacing: -0.01em;
  }
  .ig-quote-author {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 8px;
  }
  .ig-quote-author-line {
    width: 48px;
    height: 3px;
    background: {{ theme.accent1 }};
    border-radius: 2px;
  }
  .ig-quote-author-name {
    font-family: 'Manrope', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: {{ theme.accent1 }};
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ════════════════════════════════════════════
     STAT SLIDE
  ════════════════════════════════════════════ */
  .ig-stat-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 40px;
  }
  .ig-stat-grid {
    display: grid;
    grid-template-columns: {% if slide.stats | length == 2 %}1fr 1fr{% elif slide.stats | length == 3 %}1fr 1fr 1fr{% else %}1fr 1fr{% endif %};
    gap: 28px;
  }
  .ig-stat-card {
    background: {{ theme.surface | default('rgba(255,255,255,0.06)') }};
    border: 1px solid {{ theme.accent1 }}25;
    border-radius: 24px;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: hidden;
  }
  .ig-stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: {{ theme.rule }};
    border-radius: 24px 24px 0 0;
  }
  .ig-stat-number {
    font-family: 'Clash Display', sans-serif;
    font-size: 72px;
    font-weight: 700;
    color: {{ theme.accent1 }};
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .ig-stat-label {
    font-family: 'Manrope', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: {{ theme.text_muted }};
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ════════════════════════════════════════════
     COMPARE SLIDE
  ════════════════════════════════════════════ */
  .ig-compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    flex: 1;
    margin-top: 8px;
  }
  .ig-compare-col {
    background: {{ theme.surface | default('rgba(255,255,255,0.06)') }};
    border: 1px solid {{ theme.accent1 }}20;
    border-radius: 24px;
    padding: 36px 32px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .ig-compare-col:first-child {
    border-top: 4px solid {{ theme.accent1 }};
  }
  .ig-compare-col:last-child {
    border-top: 4px solid {{ theme.accent2 }};
  }
  .ig-compare-col::after {
    content: '';
    position: absolute;
    top: -30px; right: -30px;
    width: 100px; height: 100px;
    border-radius: 50%;
    opacity: 0.08;
    filter: blur(20px);
  }
  .ig-compare-col:first-child::after { background: {{ theme.accent1 }}; }
  .ig-compare-col:last-child::after { background: {{ theme.accent2 }}; }

  .ig-compare-head {
    font-family: 'Clash Display', sans-serif;
    font-size: {% if slide.is_compact %}28px{% else %}34px{% endif %};
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 20px;
    line-height: 1.2;
  }
  .ig-compare-head:first-of-type { color: {{ theme.accent1 }}; }
  .ig-compare-col:last-child .ig-compare-head { color: {{ theme.accent2 }}; }

  .ig-compare-body {
    font-family: 'Manrope', sans-serif;
    font-size: {{ slide.text_size | default(26) }}px;
    color: {{ theme.text_muted }};
    line-height: 1.55;
    flex: 1;
  }
  .ig-compare-body strong { color: {{ theme.text }}; font-weight: 700; }
  .ig-compare-body em { color: {{ theme.accent3 }}; font-style: italic; }
  .ig-compare-body code {
    background: {{ theme.surface | default('rgba(255,255,255,0.08)') }};
    padding: 2px 8px;
    border-radius: 5px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88em;
    color: {{ theme.accent2 }};
  }
  .ig-compare-body .bullets { margin-top: 8px; margin-bottom: 8px; }

  .ig-compare-tag {
    display: inline-block;
    font-family: 'Manrope', sans-serif;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 8px 18px;
    border-radius: 100px;
    margin-top: 20px;
    background: transparent;
    border: 1.5px solid var(--tag-color);
    color: var(--tag-color);
  }

  /* ════════════════════════════════════════════
     CTA SLIDE
  ════════════════════════════════════════════ */
  .ig-cta-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 36px;
  }
  .ig-cta-title {
    font-family: 'Clash Display', sans-serif;
    font-size: {% if slide.is_compact %}56px{% else %}68px{% endif %};
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: {{ theme.text }};
    text-transform: uppercase;
    max-width: 880px;
  }
  .ig-cta-sub {
    font-family: 'Manrope', sans-serif;
    font-size: 26px;
    font-weight: 500;
    line-height: 1.6;
    color: {{ theme.text_muted }};
    max-width: 760px;
  }
  .ig-cta-button {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    background: {{ theme.accent1 }};
    color: {{ theme.bg }};
    font-family: 'Clash Display', sans-serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 22px 48px;
    border-radius: 100px;
  }
  .ig-cta-rule-center {
    width: 80px;
    height: 4px;
    background: {{ theme.rule }};
    border-radius: 3px;
    margin: 0 auto 20px;
  }

  /* ════════════════════════════════════════════
     LIGHT THEME OVERRIDES
  ════════════════════════════════════════════ */
  {% if theme.is_light %}
  .ig-texture {
    background-image: radial-gradient({{ theme.accent1 }}18 1px, transparent 1px);
  }
  .ig-body code {
    background: {{ theme.surface | default('rgba(0,0,0,0.06)') }};
  }
  .ig-body .bullets li::before {
    border-color: {{ theme.bg }};
  }
  .ig-body .slide-quote {
    background: {{ theme.surface | default('rgba(0,0,0,0.04)') }};
  }
  .ig-stat-card {
    background: {{ theme.surface | default('rgba(0,0,0,0.05)') }};
    border-color: {{ theme.accent1 }}30;
  }
  .ig-compare-col {
    background: {{ theme.surface | default('rgba(0,0,0,0.05)') }};
  }
  .ig-counter {
    background: {{ theme.surface | default('rgba(0,0,0,0.06)') }};
  }
  {% endif %}

</style>
</head>
<body>
<div class="ig-slide">

  <!-- ── BACKGROUND ── -->
  <div class="ig-bg"></div>
  <div class="ig-glow-1"></div>
  <div class="ig-glow-2"></div>
  <div class="ig-texture"></div>

  <!-- ── TOP BAR (masquée sur la slide cover) ── -->
  {% if slide.type != "cover" %}
  <div class="ig-topbar">
    {% if slide.total and slide.index %}
    <div class="ig-counter">{{ "%02d"|format(slide.index) }} / {{ "%02d"|format(slide.total) }}</div>
    {% elif slide_index is defined and slide_total is defined %}
    <div class="ig-counter">{{ "%02d"|format(slide_index) }} / {{ "%02d"|format(slide_total) }}</div>
    {% endif %}
  </div>
  {% endif %}

  <!-- ── CONTENT ── -->
  {% if slide.type == "cover" %}
  <!-- Decorative side accent bar -->
  <div class="ig-cover-accent-bar"></div>

  <div class="ig-content">
    <div class="ig-cover-content">

      <!-- Logo toujours présent — plus petit quand une image accompagne la slide -->
      <div class="ig-cover-logo{% if slide.image_url %} ig-cover-logo-small{% endif %}">
        {% if logo_url %}<img src="{{ logo_url }}" alt="logo">{% endif %}
      </div>

      {% if slide.image_url %}
      <div class="cover-hero-image">
        <img src="{{ slide.image_url }}" alt="{{ slide.title }}"
             onerror="this.parentElement.style.display='none'">
      </div>
      {% endif %}

      {% if slide.badge %}
      <div class="ig-badge">{{ slide.badge }}</div>
      {% endif %}

      {% if slide.eyebrow %}
      <div class="ig-cover-eyebrow">{{ slide.eyebrow }}</div>
      {% endif %}

      <div class="ig-cover-title" id="ig-cover-title">{{ slide.title }}</div>

      {% if slide.body %}
      <div class="ig-cover-sub">{{ slide.body | safe }}</div>
      {% endif %}

      {% if slide.cta %}
      <div class="ig-cta">
        <div class="ig-cta-arrow">→</div>
        <div class="ig-cta-label">{{ slide.cta }}</div>
      </div>
      {% endif %}
    </div>
  </div>

  {% elif slide.type == "content" %}
  {% if slide.image_url %}
  <!-- Image héro : grande et centrée, contenu en indice compact en dessous -->
  <div class="ig-content content-hero" id="ig-main-content">
    <div class="content-hero-header">
      {% if slide.badge %}
      <div class="ig-badge">{{ slide.badge }}</div>
      {% endif %}
      <div class="ig-title" id="ig-title">{{ slide.title }}</div>
    </div>
    <div class="ig-rule" style="flex-shrink:0;margin-bottom:14px;"></div>
    <div class="content-hero-image-wrap" id="hero-img-wrap">
      <img src="{{ slide.image_url }}" alt="{{ slide.title }}"
           onerror="this.style.visibility='hidden'">
    </div>
    {% if slide.body %}
    <div class="content-hero-caption" id="ig-body">{{ slide.body | safe }}</div>
    {% endif %}
  </div>
  {% else %}
  <div class="ig-content" id="ig-main-content">
    {% if slide.badge %}
    <div class="ig-badge">{{ slide.badge }}</div>
    {% endif %}
    <div class="ig-title" id="ig-title">{{ slide.title }}</div>
    <div class="ig-rule"></div>
    <div class="ig-body" id="ig-body">{{ slide.body | safe }}</div>
  </div>
  {% endif %}

  {% elif slide.type == "quote" %}
  <div class="ig-content">
    <div class="ig-quote-content">
      <div class="ig-quote-mark">"</div>
      <div class="ig-quote-text" id="ig-cover-title">{{ slide.title or slide.body | safe }}</div>
      {% if slide.author or slide.badge %}
      <div class="ig-quote-author">
        <div class="ig-quote-author-line"></div>
        <div class="ig-quote-author-name">{{ slide.author or slide.badge }}</div>
      </div>
      {% endif %}
    </div>
  </div>

  {% elif slide.type == "stat" %}
  <div class="ig-content">
    <div class="ig-stat-content">
      {% if slide.badge %}
      <div class="ig-badge">{{ slide.badge }}</div>
      {% endif %}
      <div class="ig-title">{{ slide.title }}</div>
      <div class="ig-rule"></div>
      {% if slide.stats %}
      <div class="ig-stat-grid" id="ig-body">
        {% for stat in slide.stats %}
        <div class="ig-stat-card">
          <div class="ig-stat-number">{{ stat.value }}</div>
          <div class="ig-stat-label">{{ stat.label }}</div>
        </div>
        {% endfor %}
      </div>
      {% elif slide.body %}
      <div class="ig-body" id="ig-body">{{ slide.body | safe }}</div>
      {% endif %}
    </div>
  </div>

  {% elif slide.type == "compare" %}
  <div class="ig-content">
    {% if slide.badge %}
    <div class="ig-badge">{{ slide.badge }}</div>
    {% endif %}
    <div class="ig-title" id="ig-title">{{ slide.title }}</div>
    <div class="ig-rule"></div>
    {% if slide.image_url %}
    <div class="compare-image-banner">
      <img src="{{ slide.image_url }}" alt="{{ slide.title }}"
           onerror="this.parentElement.style.display='none'">
    </div>
    {% endif %}
    <div class="ig-compare-grid" id="ig-body">
      {% for col in slide.columns %}
      <div class="ig-compare-col">
        <div class="ig-compare-head">{{ col.title }}</div>
        <div class="ig-compare-body">{{ col.body | safe }}</div>
        {% if col.tag %}
        <div class="ig-compare-tag" style="--tag-color: {{ theme['accent' ~ loop.index] }}">
          {{ col.tag }}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>

  {% elif slide.type == "cta" %}
  <div class="ig-content">
    <div class="ig-cta-content">
      {% if slide.badge %}
      <div class="ig-badge">{{ slide.badge }}</div>
      {% endif %}
      <div class="ig-cta-rule-center"></div>
      <div class="ig-cta-title" id="ig-cover-title">{{ slide.title }}</div>
      {% if slide.body %}
      <div class="ig-cta-sub">{{ slide.body | safe }}</div>
      {% endif %}
      {% if slide.cta %}
      <div class="ig-cta-button">
        {{ slide.cta }} →
      </div>
      {% endif %}
    </div>
  </div>
  {% endif %}

  <!-- ── FOOTER (masqué sur la slide cover) ── -->
  {% if slide.type != "cover" %}
  <div class="ig-footer">
    <div class="ig-footer-left">
      <div class="ig-footer-series">{{ footer.series }}</div>
      <div class="ig-footer-author">{{ footer.author }}</div>
    </div>
    {% if logo_url %}<img src="{{ logo_url }}" class="ig-footer-logo" alt="logo">{% endif %}
  </div>
  {% endif %}

</div>

<script>
  // ── Dynamic font sizing for Instagram (1080×1080) ──
  function adjustFontSize() {
    const slideEl = document.querySelector('.ig-slide');
    const footer = document.querySelector('.ig-footer');
    const coverTitle = document.getElementById('ig-cover-title');
    const mainTitle = document.getElementById('ig-title');
    const body = document.getElementById('ig-body');
    const topbar = document.querySelector('.ig-topbar');

    if (!slideEl || !footer) return;

    const slideH = 1080;
    const topbarH = topbar ? topbar.getBoundingClientRect().height + 24 : 80;
    const footerH = footer.getBoundingClientRect().height;
    const availH = slideH - topbarH - footerH - 60; // 60px cushion

    let iterations = 0;
    const maxIter = 100;

    function contentBottom() {
      const content = document.querySelector('.ig-content');
      if (!content || !content.lastElementChild) return 0;
      return content.lastElementChild.getBoundingClientRect().bottom;
    }

    function footerTop() {
      return footer.getBoundingClientRect().top;
    }

    function isOverflowing() {
      return contentBottom() > footerTop() - 12;
    }

    while (isOverflowing() && iterations < maxIter) {
      // Cover titles
      if (coverTitle) {
        const sz = parseFloat(window.getComputedStyle(coverTitle).fontSize);
        if (sz > 32) coverTitle.style.fontSize = (sz - 2) + 'px';
      }
      // Content titles
      if (mainTitle) {
        const sz = parseFloat(window.getComputedStyle(mainTitle).fontSize);
        if (sz > 24) mainTitle.style.fontSize = (sz - 1) + 'px';
      }
      // Body text
      if (body) {
        const sz = parseFloat(window.getComputedStyle(body).fontSize);
        if (sz > 13) {
          body.style.fontSize = (sz - 0.7) + 'px';
          body.style.lineHeight = '1.4';
        }
      }
      // Sub-headings
      document.querySelectorAll('.ig-body .slide-h3').forEach(el => {
        const sz = parseFloat(window.getComputedStyle(el).fontSize);
        if (sz > 18) el.style.fontSize = (sz - 1) + 'px';
      });
      // Bullets
      document.querySelectorAll('.ig-body .bullets li').forEach(el => {
        const sz = parseFloat(window.getComputedStyle(el).fontSize);
        if (sz > 13) el.style.fontSize = (sz - 0.7) + 'px';
      });
      // Compare body
      document.querySelectorAll('.ig-compare-body').forEach(el => {
        const sz = parseFloat(window.getComputedStyle(el).fontSize);
        if (sz > 13) el.style.fontSize = (sz - 0.8) + 'px';
      });
      // Stat numbers
      document.querySelectorAll('.ig-stat-number').forEach(el => {
        const sz = parseFloat(window.getComputedStyle(el).fontSize);
        if (sz > 36) el.style.fontSize = (sz - 2) + 'px';
      });
      // Images Markdown en bloc
      document.querySelectorAll('.slide-figure').forEach(el => {
        const sz = parseFloat(el.style.maxHeight) || 220;
        if (sz > 60) el.style.maxHeight = (sz - 8) + 'px';
      });
      // Caption héro : réduire fonte si débordement
      const caption = document.getElementById('ig-body');
      if (caption && caption.closest('.content-hero')) {
        const sz = parseFloat(window.getComputedStyle(caption).fontSize);
        if (sz > 14) caption.style.fontSize = (sz - 1) + 'px';
      }
      iterations++;
    }
  }

  // Dynamic cover title sizing based on character count
  function sizeCoverTitle() {
    const el = document.getElementById('ig-cover-title');
    if (!el) return;
    const len = el.textContent.trim().length;
    let size;
    if (len < 20)       size = 110;
    else if (len < 35)  size = 90;
    else if (len < 55)  size = 72;
    else if (len < 80)  size = 58;
    else                size = 48;
    el.style.fontSize = size + 'px';
  }

  sizeCoverTitle();
  adjustFontSize();
  setTimeout(adjustFontSize, 200);
  setTimeout(adjustFontSize, 500);
  setTimeout(adjustFontSize, 900);

  // Re-déclencher adjustFontSize quand l'image héro finit de charger/décoder
  const heroImg = document.querySelector('.content-hero-image-wrap img');
  if (heroImg && !heroImg.complete) {
    heroImg.addEventListener('load', () => {
      adjustFontSize();
      setTimeout(adjustFontSize, 100);
    });
  } else if (heroImg && heroImg.complete) {
    setTimeout(adjustFontSize, 50);
  }
</script>
</body>
</html>
