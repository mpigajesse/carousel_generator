# Carousel Generator — variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Mot de passe secret pour accéder à l'application
# Laissez vide pour désactiver la protection (mode dev)
APP_PASSWORD=votre_mot_secret_ici

# Clé de session Flask (générer une clé aléatoire en production)
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-cette-cle-en-production
