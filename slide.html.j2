<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
  @import url('https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

  * { 
    margin: 0; padding: 0; box-sizing: border-box; 
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  @page {
    size: 1080px 1080px;
    margin: 0;
  }

  body {
    width: 1080px;
    height: 1080px;
    overflow: hidden;
    background: {{ theme.bg }};
    font-family: 'Manrope', sans-serif;
    color: {{ theme.text }};
    position: relative;
  }

  pre {
    white-space: pre-wrap;       
    word-wrap: break-word;       
    overflow-wrap: break-word;
    max-width: 100%;
  }

  .slide {
    width: 1080px;
    height: 1080px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 64px 72px;
    overflow: hidden;
  }

  /* --- AFRO-TECH BACKGROUNDS & SYMBOLS --- */

  /* Glowing aura of innovation */
  .innovation-glow {
    position: absolute;
    width: 800px; height: 800px;
    top: -200px; left: -200px;
    background: radial-gradient(circle, {{ theme.blob1 }}88 0%, transparent 70%);
    opacity: 0.8;
    filter: blur(60px);
    z-index: 0;
  }
  .innovation-glow-2 {
    position: absolute;
    width: 600px; height: 600px;
    bottom: -100px; right: -100px;
    background: radial-gradient(circle, {{ theme.blob2 }}88 0%, transparent 70%);
    opacity: 0.6;
    filter: blur(50px);
    z-index: 0;
  }

  /* 
   Nkonsonkonson (Chain link) - Adinkra symbol for unity & human relations
   Used here as a repeating subtle watermark symbol 
  */
  .watermark-symbol {
    position: absolute;
    color: {{ theme.accent1 }};
    opacity: 0.04;
    z-index: 1;
  }
  .symbol-1 { top: 8%; right: 10%; width: 140px; }
  .symbol-2 { bottom: 12%; left: 8%; width: 180px; transform: rotate(45deg); opacity: 0.03; color: {{ theme.accent2 }}; }
  .symbol-3 { top: 40%; right: -5%; width: 220px; transform: rotate(-20deg); }

  /* Tech Network Grid Pattern */
  .tech-grid {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: 
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 40px 40px;
    z-index: 0;
    mix-blend-mode: overlay;
  }

  /* Africa Unity Tech Lines */
  .unity-lines {
    position: absolute;
    bottom: 0; right: 0;
    width: 300px; height: 300px;
    z-index: 1;
    opacity: 0.3;
  }

  /* Contenu principal */
  .content { 
    position: relative; 
    z-index: 2; 
    flex: 1; 
    display: flex; 
    flex-direction: column; 
    min-height: 0;
    /* On enlève le max-height fixe pour laisser le JS calculer l'ajustement */
  }

  /* --- TYPOGRAPHY & LAYOUT --- */

  /* Module badge (small tags) */
  .module-badge {
    position: relative;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: .25em;
    color: {{ theme.bg }};
    background: {{ theme.accent1 }};
    text-transform: uppercase;
    margin-bottom: 20px;
    padding: 8px 18px;
    border-radius: 30px 0 30px 0; /* Afro asymmetrical shape */
    align-self: flex-start;
    display: flex; align-items: center; gap: 8px;
    box-shadow: 4px 4px 0 {{ theme.accent2 }};
  }
  .badge-icon {
    width: 14px; height: 14px;
    border: 2px solid {{ theme.bg }};
    border-radius: 50%;
  }

  /* Titre principal */
  .module-title {
    font-family: 'Clash Display', sans-serif;
    font-size: {% if slide.is_compact %}48px{% else %}58px{% endif %};
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: {% if slide.is_compact %}16px{% else %}24px{% endif %};
    text-transform: uppercase;
    letter-spacing: -0.01em;
    text-shadow: 2px 2px 0px rgba(0,0,0,0.5);
    overflow-wrap: break-word;
    word-break: break-word;
    hyphens: auto;
  }

  /* Règle colorée - Dotted / tribal rhythm */
  .rule {
    width: 140px;
    height: 6px;
    background: repeating-linear-gradient(90deg, 
      {{ theme.accent1 }} 0, {{ theme.accent1 }} 20px, 
      transparent 20px, transparent 30px
    );
    margin-bottom: {% if slide.is_compact %}20px{% else %}32px{% endif %};
    position: relative;
  }
  .rule::after { /* Second layer for innovation feel */
    content: '';
    position: absolute;
    top: 10px; left: 0;
    width: 80px; height: 2px;
    background: {{ theme.accent2 }};
  }

  /* Corps de texte */
  .body { 
    font-family: 'Manrope', sans-serif;
    font-size: {{ slide.text_size | default(32) }}px; 
    line-height: 1.55; 
    color: {{ theme.text_muted }}; 
    flex: 0 1 auto; 
    margin-top: 10px; 
  }
  .body p { margin-bottom: 0.8em; }
  
  .slide-h3 {
    font-family: 'Clash Display', sans-serif;
    font-size: 38px;
    font-weight: 700;
    margin-top: 1.2em;
    margin-bottom: 0.4em;
    color: {{ theme.accent1 }};
    letter-spacing: -0.01em;
  }

  .hl1 { color: {{ theme.accent2 }}; font-weight: 700; text-decoration: underline; text-decoration-color: {{ theme.accent1 }}; text-underline-offset: 4px; }
  .hl2 { color: {{ theme.accent3 }}; font-weight: 700; }
  .hl3 { color: {{ theme.accent1 }}; font-weight: 700; background: rgba(0,0,0,0.3); padding: 0 6px; border-radius: 4px;}
  .bold { color: {{ theme.text }}; font-weight: 700; }

  /* Bullet list with connection (Network effect) */
  .bullets { list-style: none; margin-top: 16px; position: relative; }
  /* Connection line behind bullets */
  .bullets::before {
    content: ''; position: absolute;
    left: 8px; top: 30px; bottom: 30px;
    width: 2px;
    background: rgba(255,255,255,0.08);
  }
  .bullets li {
    padding: 16px 0 16px 44px;
    position: relative;
    font-size: {{ (slide.text_size | default(32)) - 2 }}px;
    color: {{ theme.text_muted }};
    line-height: 1.5;
  }
  .bullets li:before {
    content: '';
    position: absolute;
    left: 4px; top: 28px;
    width: 10px; height: 10px;
    background: {{ theme.accent1 }};
    border-radius: 50%;
    box-shadow: 0 0 10px {{ theme.accent1 }};
  }
  .bullets li strong { color: {{ theme.text }}; }

  /* Grille comparaison */
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 10px;
    flex: 1;
  }
  .compare-col {
    background: linear-gradient(135deg, {{ theme.badge_bg }} 0%, rgba(0,0,0,0.4) 100%);
    border-radius: 20px;
    padding: 36px;
    border-top: 4px solid {{ theme.accent1 }};
    box-shadow: 0 15px 30px rgba(0,0,0,0.2);
    position: relative;
    overflow: hidden;
  }
  .compare-col::before {
    content: ''; position: absolute; top: -20px; right: -20px;
    width: 80px; height: 80px; border-radius: 50%;
    background: {{ theme.accent1 }}; opacity: 0.1; filter: blur(10px);
  }
  .compare-col:nth-child(2) {
    border-top: 4px solid {{ theme.accent2 }};
  }
  .compare-col:nth-child(2)::before { background: {{ theme.accent2 }}; }
  
  .compare-head { 
    font-family: 'Clash Display', sans-serif;
    font-size: {% if slide.is_compact %}30px{% else %}34px{% endif %}; 
    font-weight: 700; 
    margin-bottom: 20px; 
    text-transform: uppercase;
    letter-spacing: .05em;
  }
  .compare-body { font-size: {{ slide.text_size | default(28) }}px; color: {{ theme.text_muted }}; line-height: 1.5; }
  
  .compare-tag {
    display: inline-block;
    font-family: 'Manrope', sans-serif;
    font-size: 18px; font-weight: 800; text-transform: uppercase; letter-spacing: .08em;
    padding: 8px 16px; border-radius: 8px;
    margin-top: 24px;
    background: var(--bg-color); color: var(--color);
    border: 1px solid var(--color);
  }

  /* Afro-Tech Data Card (Couverture) */
  .terminal-box {
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.1);
    border-left: 8px solid {{ theme.accent1 }};
    border-radius: 0 40px 0 40px;
    padding: 50px 60px;
    margin: 20px 0;
    position: relative;
    box-shadow: 20px 20px 0 rgba(0,0,0,0.2);
    width: 100%;
  }
  /* Decorative ethnic/tech grid top right */
  .data-deco {
    position: absolute; top: 16px; right: 16px;
    display: grid; grid-template-columns: repeat(3, 8px); gap: 4px;
  }
  .deco-block { width: 8px; height: 8px; background: {{ theme.accent3 }}; }
  
  .terminal-title {
    font-family: 'Clash Display', sans-serif;
    font-size: 72px;
    font-weight: 700;
    text-transform: uppercase;
    text-align: left;
    margin: 0 0 20px;
    line-height: 1.15;
    color: {{ theme.text }};
    overflow-wrap: break-word;
    word-break: break-word;
    hyphens: auto;
  }
  .terminal-code {
    font-family: 'Manrope', sans-serif;
    font-size: 24px;
    color: {{ theme.bg }};
    background: {{ theme.accent2 }};
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 20px;
    border-radius: 40px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  /* Bouton swipe */
  .swipe-container {
    display: flex; align-items: center; gap: 24px; margin: 20px 0;
  }
  .arrow-shape {
    width: 65px; height: 65px;
    background: transparent;
    border: 3px solid {{ theme.accent1 }};
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: {{ theme.accent1 }};
    font-size: 30px;
    font-weight: bold;
    position: relative;
  }
  .arrow-shape::after {
    content: '→';
  }
  .swipe-label {
    font-family: 'Clash Display', sans-serif;
    font-size: 30px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    color: {{ theme.accent1 }};
  }

  /* Footer (Pan-African tech unity) */
  .footer {
    display: flex; justify-content: space-between; align-items: center;
    position: relative; z-index: 2; padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,.05);
  }
  .footer-left { display: flex; align-items: center; gap: 16px; }
  .footer-logo { height: 42px; width: auto; object-fit: contain; }
  .footer-series { 
    font-family: 'Manrope', sans-serif; font-size: 18px; 
    color: {{ theme.accent3 }}; letter-spacing: .15em; text-transform: uppercase; font-weight: 800;
  }
  .footer-unity {
    font-family: 'Clash Display', sans-serif; font-size: 15px;
    color: {{ theme.text_muted }}; opacity: 0.9;
    letter-spacing: .1em; font-weight: 600; text-transform: uppercase;
  }
  .footer-author { font-family: 'Manrope', sans-serif; font-size: 20px; font-weight: 700; color: {{ theme.text_muted }}; }
  
  /* Great ACT background typographic watermark */
  .act-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-10deg);
    font-family: 'Clash Display', sans-serif;
    font-size: 400px;
    font-weight: 700;
    color: {{ theme.accent1 }};
    opacity: 0.02;
    z-index: 0;
    pointer-events: none;
    white-space: nowrap;
  }
</style>
</head>
<body>
<div class="slide">
  <!-- ACT Background Watermark -->
  <div class="act-watermark">A C T</div>
  
  <!-- Glowing & Textures -->
  <div class="innovation-glow"></div>
  <div class="innovation-glow-2"></div>
  <div class="tech-grid"></div>

  <!-- SVG Nkonsonkonson (Unity / Linked) Symbol as background watermarks -->
  <svg class="watermark-symbol symbol-1" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round">
    <rect x="25" y="10" width="50" height="35" rx="17" />
    <rect x="25" y="55" width="50" height="35" rx="17" />
    <path d="M 50 10 L 50 90" stroke-width="6" />
  </svg>
  <svg class="watermark-symbol symbol-2" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="50" cy="30" r="20" />
    <circle cx="50" cy="70" r="20" />
    <circle cx="20" cy="50" r="10" />
    <circle cx="80" cy="50" r="10" />
    <path d="M 50 50 L 50 50" />
  </svg>
  <svg class="watermark-symbol symbol-3" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="4">
    <!-- Geometric diamond innovation pattern -->
    <path d="M50 10 L85 50 L50 90 L15 50 Z" />
    <path d="M50 30 L65 50 L50 70 L35 50 Z" />
    <line x1="15" y1="50" x2="85" y2="50" />
    <line x1="50" y1="10" x2="50" y2="90" />
  </svg>

  <!-- Unity Network Graphic bottom right -->
  <svg class="unity-lines" viewBox="0 0 100 100" preserveAspectRatio="none" stroke="{{ theme.accent1 }}" fill="none" stroke-width="0.5">
    <circle cx="80" cy="20" r="2" fill="{{ theme.accent2 }}" />
    <circle cx="60" cy="40" r="1.5" fill="{{ theme.accent1 }}" />
    <circle cx="90" cy="60" r="2.5" fill="{{ theme.accent3 }}" />
    <circle cx="40" cy="80" r="2" fill="{{ theme.accent1 }}" />
    <circle cx="70" cy="90" r="1.5" fill="{{ theme.accent2 }}" />
    
    <path d="M80 20 L60 40 L40 80 M60 40 L90 60 L70 90 M40 80 L70 90" />
    <path d="M80 20 L90 60" stroke-dasharray="2 2"/>
  </svg>

  <div class="content">
    {% if slide.type == "cover" %}
      <div class="module-badge">
        <div class="badge-icon"></div>
        {{ slide.badge }}
      </div>
      <div class="terminal-box">
        <div class="data-deco">
          {% for i in range(9) -%}<div class="deco-block"></div>{%- endfor %}
        </div>
        <div class="terminal-title" {% if slide.title|length > 40 %}style="font-size: 54px;"{% elif slide.title|length > 25 %}style="font-size: 60px;"{% elif slide.title|length > 15 %}style="font-size: 68px;"{% endif %}>
          {{ slide.title }}
        </div>
        {% if slide.code %}
        <div class="terminal-code">{{ slide.code | replace("SYS_CALL: ", "") | replace("SYS_CALL ", "") }}</div>
        {% endif %}
      </div>
      <div class="swipe-container">
        <div class="arrow-shape"></div>
        <div class="swipe-label">{{ slide.cta | upper }}</div>
      </div>

    {% elif slide.type == "content" %}
      <div class="module-badge">
        <div class="badge-icon"></div>
        {{ slide.badge }}
      </div>
      <div class="module-title">{{ slide.title }}</div>
      <div class="rule"></div>
      <div class="body">
        {{ slide.body | safe }}
      </div>

    {% elif slide.type == "compare" %}
      <div class="module-badge">
        <div class="badge-icon"></div>
        {{ slide.badge }}
      </div>
      <div class="module-title" {% if slide.title|length > 30 %}style="font-size:42px;"{% endif %}>{{ slide.title }}</div>
      <div class="rule"></div>
      <div class="compare-grid">
        {% for col in slide.columns %}
        <div class="compare-col">
          <div class="compare-head" style="color: {{ theme['accent' ~ loop.index] }}">{{ col.title }}</div>
          <div class="compare-body">{{ col.body | safe }}</div>
          {% if col.tag %}
          <div class="compare-tag" style="--color: {{ theme['accent' ~ loop.index] }}; --bg-color: rgba(0,0,0,0.3);">
            {{ col.tag }}
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="footer" id="slide-footer">
    <div class="footer-left">
      <img src="file:///d:/Generator/carousel_generator/static/logo/logo.png" class="footer-logo" alt="ACT Logo">
      <div>
        <div class="footer-series">{{ footer.series }}</div>
        <div class="footer-unity">Africa Centred Technology ( ACT )</div>
      </div>
    </div>
    <div class="footer-author">{{ footer.author }}</div>
  </div>
</div>

<script>
  function adjustFontSize() {
    const slide = document.querySelector('.slide');
    const content = document.querySelector('.content');
    const title = document.querySelector('.module-title');
    const body = document.querySelector('.body');
    const footer = document.getElementById('slide-footer');
    
    if (!content || !slide) return;

    let iterations = 0;
    const maxIterations = 50;
    
    // On définit la zone de sécurité (1080px - padding-bottom - footer height)
    const maxAllowedHeight = 1080 - 64; // On laisse un peu de marge
    
    function isOverflowing() {
      // On vérifie si le bas du footer dépasse 1080
      const footerRect = footer.getBoundingClientRect();
      return footerRect.bottom > 1080;
    }

    // Ajustement dynamique si ça déborde
    while (isOverflowing() && iterations < maxIterations) {
      // On diminue progressivement la taille du titre et du corps
      if (title) {
        const currentTitleSize = parseFloat(window.getComputedStyle(title).fontSize);
        if (currentTitleSize > 24) {
          title.style.fontSize = (currentTitleSize - 1) + 'px';
        }
      }
      
      if (body) {
        const currentBodySize = parseFloat(window.getComputedStyle(body).fontSize);
        if (currentBodySize > 14) {
          body.style.fontSize = (currentBodySize - 0.5) + 'px';
          
          // Ajuster aussi les puces si elles existent
          const bullets = body.querySelectorAll('.bullets li');
          bullets.forEach(li => {
            li.style.fontSize = (currentBodySize - 1.5) + 'px';
          });
        }
      }

      // Si c'est une slide de comparaison avec une grille
      const compGrid = document.querySelector('.compare-grid');
      if (compGrid) {
        const currentGridSize = parseFloat(window.getComputedStyle(compGrid).fontSize) || 28;
        // On réduit les titres des colonnes
        const gridHeads = document.querySelectorAll('.compare-head');
        gridHeads.forEach(h => {
             const hSize = parseFloat(window.getComputedStyle(h).fontSize);
             if (hSize > 18) h.style.fontSize = (hSize - 0.5) + 'px';
        });
        const gridBodies = document.querySelectorAll('.compare-body');
        gridBodies.forEach(b => {
             const bSize = parseFloat(window.getComputedStyle(b).fontSize);
             if (bSize > 14) b.style.fontSize = (bSize - 0.5) + 'px';
        });
      }

      iterations++;
    }
  }

  // Exécuter après le chargement
  window.addEventListener('load', adjustFontSize);
  // Un petit délai de sécurité pour les polices
  setTimeout(adjustFontSize, 200);
</script>
</body>
</html>
