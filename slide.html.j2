<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
  {% if fonts_css_url %}
  @import url('{{ fonts_css_url }}');
  {% else %}
  /* Fallback CDN (lancer download_fonts.py pour les fonts locales) */
  @import url('https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap');
  {% endif %}

  * {
    margin: 0; padding: 0; box-sizing: border-box;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  @page {
    size: 1080px 1080px;
    margin: 0;
  }

  body {
    width: 1080px;
    height: 1080px;
    overflow: hidden;
    background: {{ theme.bg }};
    font-family: 'Manrope', sans-serif;
    color: {{ theme.text }};
    position: relative;
  }

  pre {
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: break-word;
    max-width: 100%;
  }

  /* ── SLIDE CONTAINER ── */
  .slide {
    width: 1080px;
    height: 1080px;
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── BACKGROUND LAYER ── */
  .slide-bg {
    position: absolute;
    inset: 0;
    {% if theme.bg_gradient %}
    background: {{ theme.bg_gradient }};
    {% else %}
    background: {{ theme.bg }};
    {% endif %}
    z-index: 0;
  }

  /* Ambient glows */
  .slide-glow-1 {
    position: absolute;
    width: 800px; height: 800px;
    top: -200px; left: -200px;
    background: radial-gradient(circle, {{ theme.blob1 }}60 0%, transparent 65%);
    z-index: 1;
    pointer-events: none;
  }
  .slide-glow-2 {
    position: absolute;
    width: 650px; height: 650px;
    bottom: 50px; right: -120px;
    background: radial-gradient(circle, {{ theme.blob2 }}50 0%, transparent 65%);
    z-index: 1;
    pointer-events: none;
  }

  /* Dot-grid texture */
  .slide-texture {
    position: absolute;
    inset: 0;
    background-image: radial-gradient({{ theme.accent1 }}10 1px, transparent 1px);
    background-size: 36px 36px;
    z-index: 1;
    pointer-events: none;
  }

  /* ── TOP BAR ── */
  .slide-topbar {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 36px 72px 0 72px;
    flex-shrink: 0;
  }
  .slide-counter {
    font-family: 'JetBrains Mono', monospace;
    font-size: 20px;
    font-weight: 700;
    color: {{ theme.text_muted }};
    letter-spacing: 0.08em;
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }};
    padding: 8px 18px;
    border-radius: 100px;
    border: 1px solid {{ theme.accent1 }}30;
  }

  /* ── MAIN CONTENT AREA ── */
  .content {
    position: relative;
    z-index: 5;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 24px 72px 0 72px;
    min-height: 0;
  }

  /* ── FOOTER ── */
  .footer {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 72px 36px 72px;
    flex-shrink: 0;
    border-top: 1px solid {{ theme.accent1 }}20;
    margin-top: 20px;
  }
  .footer::before {
    content: '';
    position: absolute;
    top: -1px; left: 72px;
    width: 60px;
    height: 3px;
    background: {{ theme.rule }};
    border-radius: 2px;
  }
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .footer-series {
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: {{ theme.accent1 }};
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .footer-author {
    font-family: 'Manrope', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: {{ theme.text_muted }};
  }
  .footer-logo {
    height: 96px;
    width: auto;
    object-fit: contain;
    {% if theme.is_light %}opacity: 0.85;{% endif %}
  }

  /* ── BADGE ── */
  .module-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Manrope', sans-serif;
    font-size: 17px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ theme.bg }};
    background: {{ theme.accent1 }};
    padding: 8px 20px;
    border-radius: 100px;
    margin-bottom: 28px;
    align-self: flex-start;
  }
  .module-badge:empty { display: none; }

  /* ── ACCENT RULE ── */
  .rule {
    width: 80px;
    height: 5px;
    background: {{ theme.rule }};
    border-radius: 3px;
    margin-bottom: 28px;
    flex-shrink: 0;
  }

  /* ════════════════════════════════════════════
     COVER SLIDE
  ════════════════════════════════════════════ */
  .cover-logo {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 28px;
  }
  .cover-logo img {
    height: 350px;
    width: auto;
    object-fit: contain;
    {% if theme.is_light %}opacity: 0.85;{% endif %}
  }

  .cover-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .cover-eyebrow {
    font-family: 'Manrope', sans-serif;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: {{ theme.accent1 }};
    margin-bottom: 24px;
  }

  .cover-title {
    font-family: 'Clash Display', sans-serif;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: {{ theme.text }};
    text-transform: uppercase;
    word-break: break-word;
    hyphens: auto;
    margin-bottom: 24px;
  }

  .cover-sub {
    font-family: 'Manrope', sans-serif;
    font-size: 28px;
    font-weight: 500;
    line-height: 1.55;
    color: {{ theme.text_muted }};
    max-width: 820px;
    margin-bottom: 48px;
  }

  /* Cover swipe CTA */
  .swipe-container {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    align-self: center;
  }
  .arrow-shape {
    width: 56px; height: 56px;
    border: 2.5px solid {{ theme.accent1 }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    color: {{ theme.accent1 }};
  }
  .swipe-label {
    font-family: 'Clash Display', sans-serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ theme.accent1 }};
  }

  /* Decorative side accent bar */
  .cover-accent-bar {
    position: absolute;
    right: 0;
    top: 180px;
    width: 8px;
    height: 280px;
    background: {{ theme.rule }};
    border-radius: 4px 0 0 4px;
    z-index: 3;
  }

  /* ════════════════════════════════════════════
     CONTENT SLIDE
  ════════════════════════════════════════════ */
  .module-title {
    font-family: 'Clash Display', sans-serif;
    font-size: {% if slide.is_compact %}48px{% else %}58px{% endif %};
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: {{ theme.text }};
    word-break: break-word;
    hyphens: auto;
    margin-bottom: {% if slide.is_compact %}16px{% else %}24px{% endif %};
  }

  .body {
    font-family: 'Manrope', sans-serif;
    font-size: {{ slide.text_size | default(32) }}px;
    line-height: 1.6;
    color: {{ theme.text_muted }};
    flex: 0 1 auto;
    margin-top: 10px;
  }
  .body p { margin-bottom: 1em; text-align: left; }
  .body p:last-child { margin-bottom: 0; }

  .slide-h3 {
    font-family: 'Clash Display', sans-serif;
    font-size: {{ (slide.text_size | default(32)) + 6 }}px;
    font-weight: 700;
    color: {{ theme.accent1 }};
    margin-top: 0.8em;
    margin-bottom: 0.4em;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .slide-h4 {
    font-family: 'Manrope', sans-serif;
    font-size: {{ slide.text_size | default(32) }}px;
    font-weight: 700;
    color: {{ theme.accent2 }};
    margin-top: 0.5em;
    margin-bottom: 0.2em;
    line-height: 1.3;
  }

  /* Highlights */
  .hl1 { color: {{ theme.accent2 }}; font-weight: 700; text-decoration: underline; text-decoration-color: {{ theme.accent1 }}; text-underline-offset: 4px; }
  .hl2 { color: {{ theme.accent3 }}; font-weight: 700; }
  .hl3 { color: {{ theme.accent1 }}; font-weight: 700; background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }}; padding: 2px 8px; border-radius: 4px; }
  .bold, strong { color: {{ theme.text }}; font-weight: 700; }
  em { color: {{ theme.accent3 }}; font-style: italic; }

  /* Inline code */
  .body code,
  .compare-body code,
  .slide-quote code {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }};
    padding: 3px 9px;
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88em;
    color: {{ theme.accent2 }};
  }
  .body strong, .compare-body strong { color: {{ theme.text }}; font-weight: 700; }
  .body em, .compare-body em { color: {{ theme.accent3 }}; font-style: italic; }

  /* Bullet list */
  .bullets {
    list-style: none;
    margin-top: 16px;
    margin-bottom: 16px;
    padding-left: 6px;
    position: relative;
  }
  .bullets::before {
    content: '';
    position: absolute;
    left: 10px; top: 30px; bottom: 30px;
    width: 2px;
    background: linear-gradient(to bottom, {{ theme.accent1 }}, {{ theme.accent2 }});
    opacity: 0.25;
  }
  .bullets li {
    padding: 16px 0 16px 48px;
    position: relative;
    font-size: {{ (slide.text_size | default(32)) - 2 }}px;
    color: {{ theme.text_muted }};
    line-height: 1.55;
  }
  .bullets li::before {
    content: '';
    position: absolute;
    left: 4px; top: 26px;
    width: 14px; height: 14px;
    background: {{ theme.accent1 }};
    border-radius: 50%;
    border: 2px solid {{ theme.bg }};
  }
  .bullets li strong { color: {{ theme.text }}; font-weight: 700; }
  .bullets li em { color: {{ theme.accent3 }}; font-style: italic; }
  .bullets li code {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }};
    padding: 2px 8px;
    border-radius: 5px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88em;
    color: {{ theme.accent2 }};
  }

  /* Numbered list */
  ol.bullets.numbered {
    counter-reset: item;
    list-style: none;
  }
  ol.bullets.numbered li { counter-increment: item; }
  ol.bullets.numbered li::before {
    content: counter(item) !important;
    background: {{ theme.accent2 }};
    color: {{ theme.bg }};
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    left: 0;
    top: 22px;
    box-shadow: none;
  }

  /* Tables */
  .slide-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
    margin-bottom: 20px;
    font-size: {{ (slide.text_size | default(32)) - 4 }}px;
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.04)') }};
    border-radius: 12px;
    overflow: hidden;
  }
  .slide-table thead th {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }};
    padding: 16px 18px;
    text-align: left;
    font-weight: 700;
    color: {{ theme.text }};
    border-bottom: 3px solid {{ theme.accent1 }};
    font-size: {{ (slide.text_size | default(32)) - 2 }}px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .slide-table tbody td {
    padding: 14px 18px;
    color: {{ theme.text_muted }};
    border-bottom: 1px solid {{ theme.accent1 }}15;
    line-height: 1.5;
    vertical-align: top;
  }
  .slide-table tbody tr:last-child td { border-bottom: none; }
  .slide-table td code, .slide-table th code {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.12)') }};
    padding: 3px 10px;
    border-radius: 5px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
    color: {{ theme.accent2 }};
  }

  /* Blockquote */
  .slide-quote {
    border-left: 5px solid {{ theme.accent1 }};
    padding: 16px 24px;
    margin: 16px 0;
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.04)') }};
    border-radius: 0 12px 12px 0;
    font-style: italic;
    color: {{ theme.text_muted }};
  }
  .slide-quote strong { color: {{ theme.text }}; font-weight: 700; }

  /* HR */
  .slide-hr {
    border: none;
    height: 2px;
    background: {{ theme.rule }};
    margin: 16px 0;
    border-radius: 2px;
  }

  /* ── IMAGES (bloc Markdown dans le body) ── */
  .slide-figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 16px 0;
    flex-shrink: 1;
  }
  .slide-image {
    max-width: 100%;
    max-height: 220px;
    width: auto;
    height: auto;
    border-radius: 12px;
    object-fit: contain;
    border: 1px solid {{ theme.accent1 }}22;
    box-shadow: 0 6px 24px rgba(0,0,0,0.22);
    display: block;
  }
  .slide-image-inline {
    max-height: 140px;
    display: inline-block;
    vertical-align: middle;
    margin: 0 6px;
  }
  .slide-image-credit {
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-style: italic;
    color: {{ theme.text_muted }};
    opacity: 0.65;
    margin-top: 6px;
    text-align: center;
    max-width: 80%;
  }

  /* ── COVER : image héro (remplace le logo quand présente) ── */
  .cover-hero-image {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    flex-shrink: 0;
  }
  .cover-hero-image img {
    max-width: 88%;
    max-height: 260px;
    object-fit: contain;
    border-radius: 18px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.35);
    border: 1px solid {{ theme.accent1 }}28;
  }

  /* ── CONTENT AVEC IMAGE : image héro grande + contenu en indice dessous ── */
  .content-hero {
    /* garde flex-direction: column par défaut */
  }
  .content-hero-header {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 14px;
  }
  .content-hero-header .module-badge {
    margin-bottom: 0; /* annule le margin du badge par défaut */
    flex-shrink: 0;
  }
  .content-hero-header .module-title {
    margin-bottom: 0;
    font-size: 34px; /* compact — l'image prend la vedette */
    flex: 1;
    min-width: 0;
  }
  .content-hero-image-wrap {
    flex: 1;           /* prend tout l'espace vertical disponible */
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .content-hero-image-wrap img {
    max-width: 100%;
    max-height: 100%;
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 20px;
    box-shadow: 0 14px 56px rgba(0,0,0,0.45);
    border: 1px solid {{ theme.accent1 }}28;
  }
  /* Contenu en indice sous l'image */
  .content-hero-caption {
    flex-shrink: 0;
    margin-top: 14px;
    max-height: 130px;
    overflow: hidden;
    font-family: 'Manrope', sans-serif;
    font-size: 20px;
    line-height: 1.45;
    color: {{ theme.text_muted }};
  }
  /* Bullets en ligne (chips) sous l'image */
  .content-hero-caption .bullets {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .content-hero-caption .bullets::before { display: none; }
  .content-hero-caption .bullets li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px 5px 10px;
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.07)') }};
    border: 1px solid {{ theme.accent1 }}25;
    border-radius: 100px;
    font-size: 18px;
    color: {{ theme.text_muted }};
    line-height: 1.3;
  }
  .content-hero-caption .bullets li::before {
    content: '';
    width: 8px; height: 8px;
    background: {{ theme.accent1 }};
    border-radius: 50%;
    position: static;
    flex-shrink: 0;
  }
  .content-hero-caption .bullets li strong { color: {{ theme.text }}; }
  .content-hero-caption p { margin-bottom: 0.4em; }

  /* ── COMPARE : bannière image compacte au-dessus de la grille ── */
  .compare-image-banner {
    width: 100%;
    height: 90px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
  }
  .compare-image-banner img {
    max-height: 82px;
    max-width: 60%;
    object-fit: contain;
    border-radius: 12px;
    opacity: 0.92;
    border: 1px solid {{ theme.accent1 }}20;
  }

  /* ════════════════════════════════════════════
     COMPARE SLIDE
  ════════════════════════════════════════════ */
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    flex: 1;
    margin-top: 8px;
  }
  .compare-col {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.06)') }};
    border: 1px solid {{ theme.accent1 }}20;
    border-radius: 24px;
    padding: 36px 32px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .compare-col:first-child { border-top: 4px solid {{ theme.accent1 }}; }
  .compare-col:last-child  { border-top: 4px solid {{ theme.accent2 }}; }
  .compare-col::after {
    content: '';
    position: absolute;
    top: -30px; right: -30px;
    width: 100px; height: 100px;
    border-radius: 50%;
    opacity: 0.08;
    filter: blur(20px);
  }
  .compare-col:first-child::after { background: {{ theme.accent1 }}; }
  .compare-col:last-child::after  { background: {{ theme.accent2 }}; }

  .compare-head {
    font-family: 'Clash Display', sans-serif;
    font-size: {% if slide.is_compact %}28px{% else %}34px{% endif %};
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 20px;
    line-height: 1.2;
  }
  .compare-body {
    font-family: 'Manrope', sans-serif;
    font-size: {{ slide.text_size | default(26) }}px;
    color: {{ theme.text_muted }};
    line-height: 1.55;
    flex: 1;
  }
  .compare-body .bullets { margin-top: 8px; margin-bottom: 8px; }

  .compare-tag {
    display: inline-block;
    font-family: 'Manrope', sans-serif;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 8px 18px;
    border-radius: 100px;
    margin-top: 20px;
    background: transparent;
    border: 1.5px solid var(--tag-color);
    color: var(--tag-color);
  }

  /* ════════════════════════════════════════════
     LIGHT THEME OVERRIDES
  ════════════════════════════════════════════ */
  {% if theme.is_light %}
  .slide-texture {
    background-image: radial-gradient({{ theme.accent1 }}18 1px, transparent 1px);
  }
  .body code, .compare-body code, .slide-quote code {
    background: {{ theme.badge_bg | default('rgba(0,0,0,0.06)') }};
  }
  .bullets li::before {
    border-color: {{ theme.bg }};
  }
  .slide-quote {
    background: {{ theme.badge_bg | default('rgba(0,0,0,0.04)') }};
  }
  .compare-col {
    background: {{ theme.badge_bg | default('rgba(0,0,0,0.05)') }};
  }
  .slide-counter {
    background: {{ theme.badge_bg | default('rgba(0,0,0,0.06)') }};
  }
  {% endif %}

</style>
</head>
<body>
<div class="slide">

  <!-- ── BACKGROUND ── -->
  <div class="slide-bg"></div>
  <div class="slide-glow-1"></div>
  <div class="slide-glow-2"></div>
  <div class="slide-texture"></div>

  <!-- ── TOP BAR (masquée sur la slide cover) ── -->
  {% if slide.type != "cover" %}
  <div class="slide-topbar">
    {% if slide_index is defined and slide_total is defined %}
    <div class="slide-counter">{{ "%02d"|format(slide_index) }} / {{ "%02d"|format(slide_total) }}</div>
    {% endif %}
  </div>
  {% endif %}

  <!-- ── CONTENT ── -->
  {% if slide.type == "cover" %}
  <!-- Decorative side accent bar -->
  <div class="cover-accent-bar"></div>

  <div class="content">
    <div class="cover-content">

      {% if slide.image_url %}
      <!-- Image héro : remplace le logo, occupe la zone visuelle principale -->
      <div class="cover-hero-image">
        <img src="{{ slide.image_url }}" alt="{{ slide.title }}"
             onerror="this.parentElement.style.display='none'">
      </div>
      {% else %}
      <div class="cover-logo">
        {% if logo_url %}<img src="{{ logo_url }}" alt="logo">{% endif %}
      </div>
      {% endif %}

      {% if slide.badge %}
      <div class="module-badge">{{ slide.badge }}</div>
      {% endif %}

      {% if slide.eyebrow %}
      <div class="cover-eyebrow">{{ slide.eyebrow }}</div>
      {% endif %}

      <div class="cover-title" id="cover-title">{{ slide.title | replace("·", " · ") | replace("-", " - ") }}</div>

      {% if slide.code %}
      <div class="cover-sub">{{ slide.code }}</div>
      {% endif %}

      <div class="swipe-container">
        <div class="arrow-shape">→</div>
        <div class="swipe-label">{{ slide.cta | default("Swipe") | upper }}</div>
      </div>
    </div>
  </div>

  {% elif slide.type == "content" %}
  {% if slide.image_url %}
  <!-- Image héro : grande et centrée, contenu en indice compact en dessous -->
  <div class="content content-hero" id="main-content">
    <div class="content-hero-header">
      {% if slide.badge %}
      <div class="module-badge">{{ slide.badge }}</div>
      {% endif %}
      <div class="module-title" id="slide-title">{{ slide.title }}</div>
    </div>
    <div class="rule" style="flex-shrink:0;margin-bottom:14px;"></div>
    <div class="content-hero-image-wrap" id="hero-img-wrap">
      <img src="{{ slide.image_url }}" alt="{{ slide.title }}"
           onerror="this.parentElement.style.display='none'">
    </div>
    {% if slide.body %}
    <div class="content-hero-caption" id="slide-body">{{ slide.body | safe }}</div>
    {% endif %}
  </div>
  {% else %}
  <div class="content" id="main-content">
    {% if slide.badge %}
    <div class="module-badge">{{ slide.badge }}</div>
    {% endif %}
    <div class="module-title" id="slide-title">{{ slide.title }}</div>
    <div class="rule"></div>
    <div class="body" id="slide-body">{{ slide.body | safe }}</div>
  </div>
  {% endif %}

  {% elif slide.type == "compare" %}
  <div class="content">
    {% if slide.badge %}
    <div class="module-badge">{{ slide.badge }}</div>
    {% endif %}
    <div class="module-title" id="slide-title">{{ slide.title }}</div>
    <div class="rule"></div>
    {% if slide.image_url %}
    <!-- Bannière compacte au-dessus de la grille, hauteur fixe — pas de débordement -->
    <div class="compare-image-banner">
      <img src="{{ slide.image_url }}" alt="{{ slide.title }}"
           onerror="this.parentElement.style.display='none'">
    </div>
    {% endif %}
    <div class="compare-grid" id="slide-body">
      {% for col in slide.columns %}
      <div class="compare-col">
        <div class="compare-head" style="color: {{ theme['accent' ~ loop.index] }}">{{ col.title }}</div>
        <div class="compare-body">{{ col.body | safe }}</div>
        {% if col.tag %}
        <div class="compare-tag" style="--tag-color: {{ theme['accent' ~ loop.index] }}">
          {{ col.tag }}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>

  {% endif %}

  <!-- ── FOOTER (masqué sur la slide cover) ── -->
  {% if slide.type != "cover" %}
  <div class="footer" id="slide-footer">
    <div class="footer-left">
      <div class="footer-series">{{ footer.series }}</div>
      <div class="footer-author">{{ footer.author }}</div>
    </div>
    {% if logo_url %}<img src="{{ logo_url }}" class="footer-logo" alt="logo">{% endif %}
  </div>
  {% endif %}

</div>

<script>
  function adjustFontSize() {
    const slideEl = document.querySelector('.slide');
    const footer = document.getElementById('slide-footer');
    const coverTitle = document.getElementById('cover-title');
    const mainTitle = document.getElementById('slide-title');
    const body = document.getElementById('slide-body');
    const topbar = document.querySelector('.slide-topbar');

    if (!slideEl || !footer) return;

    const slideH = 1080;
    const topbarH = topbar ? topbar.getBoundingClientRect().height + 24 : 80;
    const footerH = footer.getBoundingClientRect().height;
    const availH = slideH - topbarH - footerH - 60;

    let iterations = 0;
    const maxIter = 100;

    function contentBottom() {
      const content = document.querySelector('.content');
      if (!content) return 0;
      // Layout héro : vérifier le bas du caption (dernier enfant visible)
      if (!content.lastElementChild) return 0;
      return content.lastElementChild.getBoundingClientRect().bottom;
    }

    function footerTop() {
      return footer.getBoundingClientRect().top;
    }

    function isOverflowing() {
      return contentBottom() > footerTop() - 12;
    }

    while (isOverflowing() && iterations < maxIter) {
      // Cover titles
      if (coverTitle) {
        const sz = parseFloat(window.getComputedStyle(coverTitle).fontSize);
        if (sz > 32) coverTitle.style.fontSize = (sz - 2) + 'px';
      }
      // Content titles
      if (mainTitle) {
        const sz = parseFloat(window.getComputedStyle(mainTitle).fontSize);
        if (sz > 24) mainTitle.style.fontSize = (sz - 1) + 'px';
      }
      // Body text
      if (body) {
        const sz = parseFloat(window.getComputedStyle(body).fontSize);
        if (sz > 13) {
          body.style.fontSize = (sz - 0.7) + 'px';
          body.style.lineHeight = '1.4';
        }
      }
      // Sub-headings
      document.querySelectorAll('.slide-h3').forEach(el => {
        const sz = parseFloat(window.getComputedStyle(el).fontSize);
        if (sz > 18) el.style.fontSize = (sz - 1) + 'px';
      });
      // Bullets
      document.querySelectorAll('.bullets li').forEach(el => {
        const sz = parseFloat(window.getComputedStyle(el).fontSize);
        if (sz > 13) el.style.fontSize = (sz - 0.7) + 'px';
      });
      // Compare
      document.querySelectorAll('.compare-head, .compare-body').forEach(el => {
        const sz = parseFloat(window.getComputedStyle(el).fontSize);
        if (sz > 14) el.style.fontSize = (sz - 1) + 'px';
      });
      // Images Markdown en bloc
      document.querySelectorAll('.slide-figure').forEach(el => {
        const sz = parseFloat(el.style.maxHeight) || 220;
        if (sz > 60) el.style.maxHeight = (sz - 8) + 'px';
      });
      // Caption héro : réduire fonte si débordement
      const caption = document.getElementById('slide-body');
      if (caption && caption.closest('.content-hero')) {
        const sz = parseFloat(window.getComputedStyle(caption).fontSize);
        if (sz > 14) caption.style.fontSize = (sz - 1) + 'px';
      }
      iterations++;
    }
  }

  // Dynamic cover title sizing
  function sizeCoverTitle() {
    const el = document.getElementById('cover-title');
    if (!el) return;
    const len = el.textContent.trim().length;
    let size;
    if (len < 20)       size = 110;
    else if (len < 35)  size = 90;
    else if (len < 55)  size = 72;
    else if (len < 80)  size = 58;
    else                size = 48;
    el.style.fontSize = size + 'px';
  }

  sizeCoverTitle();
  adjustFontSize();
  setTimeout(adjustFontSize, 200);
  setTimeout(adjustFontSize, 500);
  setTimeout(adjustFontSize, 900);
</script>
</body>
</html>
