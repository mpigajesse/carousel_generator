<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=JetBrains+Mono:wght@400;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    width: 1080px;
    height: 1080px;
    overflow: hidden;
    background: {{ theme.bg }};
    font-family: 'Space Grotesk', sans-serif;
    color: {{ theme.text }};
    position: relative;
  }

  .slide {
    width: 1080px;
    height: 1080px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 72px;
    overflow: hidden;
  }

  /* Blobs décoratifs */
  .blob {
    position: absolute;
    border-radius: 50%;
    opacity: 0.35;
  }
  .blob-tl {
    width: 380px; height: 380px;
    top: -100px; left: -100px;
    background: {{ theme.blob1 }};
  }
  .blob-br {
    width: 320px; height: 320px;
    bottom: -80px; right: -60px;
    background: {{ theme.blob2 }};
  }

  /* Contenu principal */
  .content { position: relative; z-index: 2; flex: 1; display: flex; flex-direction: column; }

  /* Module badge */
  .module-badge {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: .18em;
    color: {{ theme.accent1 }};
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  /* Titre principal */
  .module-title {
    font-size: 56px;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 28px;
  }

  /* Règle colorée */
  .rule {
    width: 64px;
    height: 5px;
    background: {{ theme.rule }};
    border-radius: 3px;
    margin-bottom: 40px;
  }

  /* Corps de texte */
  .body { font-size: {{ slide.text_size | default(30) }}px; line-height: 1.65; color: {{ theme.text_muted }}; flex: 1; overflow: hidden; }

  .hl1 { color: {{ theme.accent2 }}; font-weight: 600; }
  .hl2 { color: {{ theme.accent3 }}; font-weight: 600; }
  .hl3 { color: {{ theme.accent1 }}; font-weight: 600; }
  .bold { color: {{ theme.text }}; font-weight: 700; }

  /* Bullet list */
  .bullets { list-style: none; margin-top: 20px; }
  .bullets li {
    padding: 16px 0 16px 40px;
    position: relative;
    border-bottom: 1px solid rgba(255,255,255,.06);
    font-size: {{ (slide.text_size | default(30)) - 2 }}px;
    color: {{ theme.text_muted }};
    line-height: 1.5;
  }
  .bullets li:before {
    content: '';
    position: absolute;
    left: 0; top: 28px;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: {{ theme.accent1 }};
  }
  .bullets li strong { color: {{ theme.text }}; }

  /* Grille comparaison */
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 20px;
    flex: 1;
  }
  .compare-col {
    background: {{ theme.badge_bg }};
    border-radius: 20px;
    padding: 32px;
    border: 1px solid rgba(255,255,255,.08);
  }
  .compare-head { font-size: 30px; font-weight: 700; margin-bottom: 16px; }
  .compare-body { font-size: 26px; color: {{ theme.text_muted }}; line-height: 1.55; }
  .compare-tag {
    display: inline-block;
    font-size: 22px;
    font-weight: 600;
    padding: 6px 20px;
    border-radius: 8px;
    margin-top: 20px;
  }
  .tag-accent1 { background: rgba({{ theme.accent1|hex_to_rgb }}, .15); color: {{ theme.accent1 }}; }
  .tag-accent2 { background: rgba({{ theme.accent2|hex_to_rgb }}, .15); color: {{ theme.accent2 }}; }

  /* Terminal box (slide de couverture) */
  .terminal-box {
    background: {{ theme.terminal_bg }};
    border: 2px solid {{ theme.terminal_border }};
    border-radius: 24px;
    padding: 40px 48px;
    margin: 40px 0;
  }
  .terminal-dots { display: flex; gap: 12px; margin-bottom: 28px; }
  .dot { width: 22px; height: 22px; border-radius: 50%; }
  .dot-r { background: #ef4444; }
  .dot-y { background: #f59e0b; }
  .dot-g { background: #22c55e; }
  .terminal-title {
    font-size: 72px;
    font-weight: 700;
    text-align: center;
    margin: 16px 0 8px;
  }
  .terminal-code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 30px;
    color: {{ theme.text_muted }};
    text-align: center;
  }

  /* Bouton swipe */
  .arrow-circle {
    width: 110px; height: 110px;
    border-radius: 50%;
    background: {{ theme.blob1 }};
    display: flex; align-items: center; justify-content: center;
    font-size: 48px;
    margin: 24px auto;
  }
  .swipe-label {
    font-size: 34px;
    font-weight: 700;
    text-align: center;
    letter-spacing: .08em;
  }

  /* Footer */
  .footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 2;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,.07);
  }
  .footer-series { font-size: 20px; color: rgba(255,255,255,.3); letter-spacing: .1em; text-transform: uppercase; }
  .footer-author { font-size: 22px; font-weight: 600; color: {{ theme.text_muted }}; }
</style>
</head>
<body>
<div class="slide">
  <div class="blob blob-tl"></div>
  <div class="blob blob-br"></div>

  <div class="content">
    {% if slide.type == "cover" %}
      <div class="module-badge" style="text-align:center">{{ slide.badge }}</div>
      <div class="terminal-box">
        <div class="terminal-dots">
          <div class="dot dot-r"></div>
          <div class="dot dot-y"></div>
          <div class="dot dot-g"></div>
        </div>
        <div class="terminal-title">{{ slide.title }}</div>
        <div class="terminal-code">&gt; {{ slide.code }}</div>
      </div>
      <div class="arrow-circle">→</div>
      <div class="swipe-label">{{ slide.cta | upper }}</div>

    {% elif slide.type == "content" %}
      <div class="module-badge">{{ slide.badge }}</div>
      <div class="module-title">{{ slide.title }}</div>
      <div class="rule"></div>
      <div class="body">
        {{ slide.body | safe }}
      </div>

    {% elif slide.type == "compare" %}
      <div class="module-badge">{{ slide.badge }}</div>
      <div class="module-title">{{ slide.title }}</div>
      <div class="rule"></div>
      <div class="compare-grid">
        {% for col in slide.columns %}
        <div class="compare-col">
          <div class="compare-head" style="color: {{ theme['accent' ~ loop.index] }}">{{ col.title }}</div>
          <div class="compare-body">{{ col.body | safe }}</div>
          {% if col.tag %}
          <div class="compare-tag tag-accent{{ loop.index }}">{{ col.tag }}</div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="footer">
    <div class="footer-series">{{ footer.series }}</div>
    <div class="footer-author">{{ footer.author }}</div>
  </div>
</div>
</body>
</html>
