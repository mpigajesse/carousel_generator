<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
  {% if fonts_css_url %}
  @import url('{{ fonts_css_url }}');
  {% else %}
  /* Fallback CDN (lancer download_fonts.py pour les fonts locales) */
  @import url('https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap');
  {% endif %}

  /* ── Dynamic theme tokens (Jinja2 rendered) ── */
  body {
    background: {{ theme.bg }};
    color: {{ theme.text }};
  }

  .slide-bg {
    {% if theme.bg_gradient %}
    background: {{ theme.bg_gradient }};
    {% else %}
    background: {{ theme.bg }};
    {% endif %}
  }

  .slide-glow-1 {
    background: radial-gradient(circle, {{ theme.blob1 }}60 0%, transparent 65%);
  }
  .slide-glow-2 {
    background: radial-gradient(circle, {{ theme.blob2 }}50 0%, transparent 65%);
  }

  .slide-texture {
    background-image: radial-gradient({{ theme.accent1 }}10 1px, transparent 1px);
  }

  .slide-counter {
    color: {{ theme.text_muted }};
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }};
    border: 1px solid {{ theme.accent1 }}30;
  }

  .footer {
    border-top: 1px solid {{ theme.accent1 }}20;
  }
  .footer::before {
    background: {{ theme.rule }};
  }
  .footer-series {
    color: {{ theme.accent1 }};
  }
  .footer-author {
    color: {{ theme.text_muted }};
  }
  {% if theme.is_light %}.footer-logo { opacity: 0.85; }{% endif %}

  .module-badge {
    color: {{ theme.bg }};
    background: {{ theme.accent1 }};
  }

  .rule {
    background: {{ theme.rule }};
  }

  {% if theme.is_light %}.cover-logo img { opacity: 0.85; }{% endif %}

  .cover-eyebrow {
    color: {{ theme.accent1 }};
  }

  .cover-title {
    color: {{ theme.text }};
  }

  .cover-sub {
    color: {{ theme.text_muted }};
  }

  .arrow-shape {
    border: 2.5px solid {{ theme.accent1 }};
    color: {{ theme.accent1 }};
  }
  .swipe-label {
    color: {{ theme.accent1 }};
  }

  .cover-accent-bar {
    background: {{ theme.rule }};
  }

  .module-title {
    font-size: {% if slide.is_compact %}48px{% else %}58px{% endif %};
    color: {{ theme.text }};
    margin-bottom: {% if slide.is_compact %}16px{% else %}24px{% endif %};
  }

  .body {
    font-size: {{ slide.text_size | default(32) }}px;
    color: {{ theme.text_muted }};
  }

  .slide-h3 {
    font-size: {{ (slide.text_size | default(32)) + 6 }}px;
    color: {{ theme.accent1 }};
  }
  .slide-h4 {
    font-size: {{ slide.text_size | default(32) }}px;
    color: {{ theme.accent2 }};
  }

  .hl1 { color: {{ theme.accent2 }}; text-decoration-color: {{ theme.accent1 }}; }
  .hl2 { color: {{ theme.accent3 }}; }
  .hl3 { color: {{ theme.accent1 }}; background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }}; }
  .bold, strong { color: {{ theme.text }}; }
  em { color: {{ theme.accent3 }}; }

  .body code,
  .compare-body code,
  .slide-quote code {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }};
    color: {{ theme.accent2 }};
  }
  .body strong, .compare-body strong { color: {{ theme.text }}; }
  .body em, .compare-body em { color: {{ theme.accent3 }}; }

  .bullets::before {
    background: linear-gradient(to bottom, {{ theme.accent1 }}, {{ theme.accent2 }});
  }
  .bullets li {
    font-size: {{ (slide.text_size | default(32)) - 2 }}px;
    color: {{ theme.text_muted }};
  }
  .bullets li::before {
    background: {{ theme.accent1 }};
    border: 2px solid {{ theme.bg }};
  }
  .bullets li strong { color: {{ theme.text }}; }
  .bullets li em { color: {{ theme.accent3 }}; }
  .bullets li code {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }};
    color: {{ theme.accent2 }};
  }

  ol.bullets.numbered li::before {
    background: {{ theme.accent2 }};
    color: {{ theme.bg }};
  }

  .slide-table {
    font-size: {{ (slide.text_size | default(32)) - 4 }}px;
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.04)') }};
  }
  .slide-table thead th {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.08)') }};
    color: {{ theme.text }};
    border-bottom: 3px solid {{ theme.accent1 }};
    font-size: {{ (slide.text_size | default(32)) - 2 }}px;
  }
  .slide-table tbody td {
    color: {{ theme.text_muted }};
    border-bottom: 1px solid {{ theme.accent1 }}15;
  }
  .slide-table td code, .slide-table th code {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.12)') }};
    color: {{ theme.accent2 }};
  }

  .slide-quote {
    border-left-color: {{ theme.accent1 }};
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.04)') }};
    color: {{ theme.text_muted }};
  }
  .slide-quote strong { color: {{ theme.text }}; }

  .slide-hr {
    background: {{ theme.rule }};
  }

  .slide-image {
    border: 1px solid {{ theme.accent1 }}22;
  }
  .slide-image-credit {
    color: {{ theme.text_muted }};
  }

  .cover-hero-image img {
    border: 1px solid {{ theme.accent1 }}28;
  }

  .content-hero-image-wrap img {
    border: 1px solid {{ theme.accent1 }}28;
  }
  .content-hero-caption {
    color: {{ theme.text_muted }};
  }
  .content-hero-caption .bullets li {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.07)') }};
    border: 1px solid {{ theme.accent1 }}25;
    color: {{ theme.text_muted }};
  }
  .content-hero-caption .bullets li::before {
    background: {{ theme.accent1 }};
  }
  .content-hero-caption .bullets li strong { color: {{ theme.text }}; }

  .compare-image-banner img {
    border: 1px solid {{ theme.accent1 }}20;
  }

  .compare-col {
    background: {{ theme.badge_bg | default('rgba(255,255,255,0.06)') }};
    border: 1px solid {{ theme.accent1 }}20;
  }
  .compare-col:first-child { border-top: 4px solid {{ theme.accent1 }}; }
  .compare-col:last-child  { border-top: 4px solid {{ theme.accent2 }}; }
  .compare-col:first-child::after { background: {{ theme.accent1 }}; }
  .compare-col:last-child::after  { background: {{ theme.accent2 }}; }

  .compare-head {
    font-size: {% if slide.is_compact %}28px{% else %}34px{% endif %};
  }
  .compare-body {
    font-size: {{ slide.text_size | default(26) }}px;
    color: {{ theme.text_muted }};
  }

  /* ── Light theme overrides ── */
  {% if theme.is_light %}
  .slide-texture {
    background-image: radial-gradient({{ theme.accent1 }}18 1px, transparent 1px);
  }
  .body code, .compare-body code, .slide-quote code {
    background: {{ theme.badge_bg | default('rgba(0,0,0,0.06)') }};
  }
  .bullets li::before {
    border-color: {{ theme.bg }};
  }
  .slide-quote {
    background: {{ theme.badge_bg | default('rgba(0,0,0,0.04)') }};
  }
  .compare-col {
    background: {{ theme.badge_bg | default('rgba(0,0,0,0.05)') }};
  }
  .slide-counter {
    background: {{ theme.badge_bg | default('rgba(0,0,0,0.06)') }};
  }
  {% endif %}

  /* ── Static CSS (inlined by Jinja2 at render time) ── */
  {% include 'static/css/slide-base.css' %}
  {% include 'static/css/slide-linkedin.css' %}
</style>
</head>
<body>
<div class="slide">

  <!-- ── BACKGROUND ── -->
  <div class="slide-bg"></div>
  <div class="slide-glow-1"></div>
  <div class="slide-glow-2"></div>
  <div class="slide-texture"></div>

  <!-- ── TOP BAR (masquée sur la slide cover) ── -->
  {% if slide.type != "cover" %}
  <div class="slide-topbar">
    {% if slide_index is defined and slide_total is defined %}
    <div class="slide-counter">{{ "%02d"|format(slide_index) }} / {{ "%02d"|format(slide_total) }}</div>
    {% endif %}
  </div>
  {% endif %}

  <!-- ── CONTENT ── -->
  {% if slide.type == "cover" %}
  <!-- Decorative side accent bar -->
  <div class="cover-accent-bar"></div>

  <div class="content">
    <div class="cover-content">

      <!-- Logo toujours présent — plus petit quand une image accompagne la slide -->
      <div class="cover-logo{% if slide.image_url %} cover-logo-small{% endif %}">
        {% if logo_url %}<img src="{{ logo_url }}" alt="logo">{% endif %}
      </div>

      {% if slide.image_url %}
      <div class="cover-hero-image">
        <img src="{{ slide.image_url }}" alt="{{ slide.title }}"
             onerror="this.parentElement.style.display='none'">
      </div>
      {% endif %}

      {% if slide.badge %}
      <div class="module-badge">{{ slide.badge }}</div>
      {% endif %}

      {% if slide.eyebrow %}
      <div class="cover-eyebrow">{{ slide.eyebrow }}</div>
      {% endif %}

      <div class="cover-title" id="cover-title">{{ slide.title | replace("·", " · ") | replace("-", " - ") }}</div>

      {% if slide.code %}
      <div class="cover-sub">{{ slide.code }}</div>
      {% endif %}

      <div class="swipe-container">
        <div class="arrow-shape">→</div>
        <div class="swipe-label">{{ slide.cta | default("Swipe") | upper }}</div>
      </div>
    </div>
  </div>

  {% elif slide.type == "content" %}
  {% if slide.image_url %}
  <!-- Image héro : grande et centrée, contenu en indice compact en dessous -->
  <div class="content content-hero" id="main-content">
    <div class="content-hero-header">
      {% if slide.badge %}
      <div class="module-badge">{{ slide.badge }}</div>
      {% endif %}
      <div class="module-title" id="slide-title">{{ slide.title }}</div>
    </div>
    <div class="rule" style="flex-shrink:0;margin-bottom:14px;"></div>
    <div class="content-hero-image-wrap" id="hero-img-wrap">
      <img src="{{ slide.image_url }}" alt="{{ slide.title }}"
           onerror="this.style.visibility='hidden'">
    </div>
    {% if slide.body %}
    <div class="content-hero-caption" id="slide-body">{{ slide.body | safe }}</div>
    {% endif %}
  </div>
  {% else %}
  <div class="content" id="main-content">
    {% if slide.badge %}
    <div class="module-badge">{{ slide.badge }}</div>
    {% endif %}
    <div class="module-title" id="slide-title">{{ slide.title }}</div>
    <div class="rule"></div>
    <div class="body" id="slide-body">{{ slide.body | safe }}</div>
  </div>
  {% endif %}

  {% elif slide.type == "compare" %}
  <div class="content">
    {% if slide.badge %}
    <div class="module-badge">{{ slide.badge }}</div>
    {% endif %}
    <div class="module-title" id="slide-title">{{ slide.title }}</div>
    <div class="rule"></div>
    {% if slide.image_url %}
    <!-- Bannière compacte au-dessus de la grille, hauteur fixe — pas de débordement -->
    <div class="compare-image-banner">
      <img src="{{ slide.image_url }}" alt="{{ slide.title }}"
           onerror="this.parentElement.style.display='none'">
    </div>
    {% endif %}
    <div class="compare-grid" id="slide-body">
      {% for col in slide.columns %}
      <div class="compare-col">
        <div class="compare-head" style="color: {{ theme['accent' ~ loop.index] }}">{{ col.title }}</div>
        <div class="compare-body">{{ col.body | safe }}</div>
        {% if col.tag %}
        <div class="compare-tag" style="--tag-color: {{ theme['accent' ~ loop.index] }}">
          {{ col.tag }}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>

  {% endif %}

  <!-- ── FOOTER (masqué sur la slide cover) ── -->
  {% if slide.type != "cover" %}
  <div class="footer" id="slide-footer">
    <div class="footer-left">
      <div class="footer-series">{{ footer.series }}</div>
      <div class="footer-author">{{ footer.author }}</div>
    </div>
    {% if logo_url %}<img src="{{ logo_url }}" class="footer-logo" alt="logo">{% endif %}
  </div>
  {% endif %}

</div>

<script>
{% include 'static/js/slide-linkedin.js' %}
{% include 'static/js/slide-core.js' %}
</script>
</body>
</html>
